{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TekReportPro",
  "version": "1.1.3",
  "identifier": "com.tekreportpro.assistant",
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGMzM4NjA0QjlGNzhEQUQKUldTdGpmZTVCSVl6bjExNWl2VDJ2QXZiM3RvdnoxY3NkMGU5alRhdEpESm9MckEvOEYrdnp0NXMK",
      "endpoints": [
        "https://github.com/Livex97/TekReportPro/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "windows": {
        "installMode": "passive"
      },
      "macos": {
        "installMode": "passive"
      },
      "linux": {
        "installMode": "passive"
      }
    }
  },
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TekReportPro",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/save_pandetta",
      "binaries/save_sterlink",
      "binaries/read_excel",
      "binaries/check_email"
    ]
  }
}