{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RapportiniApp",
  "version": "0.8.0",
  "identifier": "com.rapportini.assistant",
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "",
      "endpoints": [
        "https://api.github.com/repos/Livex97/RapportiniApp/releases/latest"
      ],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      },
      "macos": {
        "installMode": "passive"
      },
      "linux": {
        "installMode": "passive"
      }
    }
  },
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rapportini App",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}